# =============================================================
# TravelMate Backend — Environment Variables Template
# =============================================================
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# =============================================================

PORT=8080
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_123

# Supabase
SUPABASE_URL=https://<your-project-id>.supabase.co/rest/v1/
SUPABASE_KEY=your_supabase_secret_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here

# Groq AI
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# News API
NEWS_API_KEY=your_news_api_key_here

# Unsplash
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Inngest
INNGEST_ENV=dev
# For production later:
# INNGEST_API_KEY=<your-inngest-cloud-key>

# Open-Meteo: No API key needed — call https://api.open-meteo.com directly
